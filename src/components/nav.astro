---
import { Image } from 'astro:assets';
import Logo from '../assets/delicias3.png';
import "../styles/style.css"
---



<nav class="navbar navbar-expand-lg navbar-custom" >

  <div class="container">
    <a class="navbar-brand" href="/"><Image src={Logo} alt="Logo" width="115" height="50" /></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/#inicio">Inicio</a></li>
        <li class="nav-item"><a class="nav-link" href="/#nosotros">Nosotros</a></li>
        <li class="nav-item"><a class="nav-link" href="/#productos">Productos</a></li>
        <li class="nav-item"><a class="nav-link" href="/#reseñas">Reseñas</a></li>
        <li class="nav-item"><a class="nav-link" href="/#contactanos">Contactanos</a></li>
      </ul>

      <ul class="navbar-nav sm-icons mr-0">
        <li><a class="nav-link" href="/libro"><i class="bi bi-book-fill"></i></a></li>
        <li >
          <a class="nav-link" href="/carrito"><i class="bi bi-cart3"></i> <span id="cart-counter">0</span></a>
        </li>


        <!-- ✅ Usuario autenticado -->
        

        <!-- ✅ Icono para iniciar sesión si NO está logueado -->
        <li class="nav-item login-right">
          <a class="nav-link" href="/sesion"><i class="bi bi-person-fill"></i> Iniciar sesión</a>
        </li>
      </ul>
    </div>
  </div>
</nav>
